Host *
  SendEnv LANG LC_*
  MACs hmac-md5,hmac-sha1
  ForwardX11 no
  ForwardAgent yes
  AddressFamily inet
  ServerAliveInterval 15
  ConnectTimeout 20
  # Bare single-label names (no dots) get netbird.cloud appended when that resolves,
  # so `ssh ome-nas-1` / `ssh mw-ws-hq01` work with zero per-host entries — including
  # fleet hosts added later. Names with dots and IPs (all HostName values below) are
  # left alone; unresolvable names fall back to normal lookup (LAN, /etc/hosts).
  CanonicalizeHostname yes
  CanonicalDomains netbird.cloud
  CanonicalizeMaxDots 0
  CanonicalizeFallbackLocal yes

Host gitlab.mwlab.dev
    HostName mw-lab-gitlab.netbird.cloud
    User git

Host bastion
    User ec2-user
    Hostname bastion.domain.com
    IdentityFile ~/.ssh/id_rsa

