#!/usr/bin/env python3
"""claude-team-watch -- supervisor for a claude-team herdr session.

Connects to the herdr unix socket, subscribes to agent-status / pane / tab
events for the workspace whose label matches the given session, and:
  * notifies (herdr notification show) when an agent goes blocked
  * collects a finished agent's recent output into <project>/.claude-team/results/
  * prints every state transition as a compact timestamped line (--json for JSONL)
  * completion protocol: when an agent with a declared deliverable (manifest
    checks) finishes, runs `claude-team verify` first; unmet -> nudge the agent
    back to work (max 2), then escalate to the human. Collect/reap only after
    the deliverable verifies. Watch owns all manifest writes after seeding.

Stdlib only. Invoked by `claude-team watch <session>` (which exports
CLAUDE_TEAM_BIN so verify can be shelled out to).
Reviews are non-blocking: spawning a reviewer registers it as in-flight
(register_review) and returns; a timed loop tick (select) polls in-flight
reviews (poll_reviews) and resolves each independently once its verdict
artifact lands or its deadline passes, so concurrent reviews never serialize.
v1 constraint: run_verify() is still called synchronously from the single event
loop (handle() -> protocol_on_finished()), so a slow deliverable check
(subprocess timeout up to 120s, plus the branch_pushed ls-remote) blocks
delivery of every other event for up to ~3 minutes worst case. Fine for a
handful of agents; would need a worker pool for larger teams.
Protocol notes (verified against herdr 0.7.1 / protocol 14):
  * RPC connections are one-shot: the server closes after one reply.
  * events.subscribe holds its connection open and streams NDJSON events.
  * Subscribing replays historical pane/tab created events, so re-subscribe
    triggers are guarded by known pane/tab sets.
"""

import json
import os
import select
import shutil
import signal
import socket
import subprocess
import sys
import time
from datetime import datetime

DEFAULT_SOCKET = os.path.expanduser("~/.config/herdr/herdr.sock")
HERDR = os.environ.get("HERDR_BIN") or shutil.which("herdr") \
    or "/opt/homebrew/opt/herdr/bin/herdr"
USAGE = """usage: claude-team-watch <session> [--socket PATH] [--json] [--reap]

Supervise a claude-team herdr session (session = workspace label):
print agent state transitions, notify when an agent blocks, and collect
output into <project>/.claude-team/results/ when an agent finishes.
Agents with a declared deliverable are verify-gated: unmet deliverables
get nudged (max 2) then escalated; collection waits for verification.

--reap: after a finished agent's output is collected, close its tab
(never the tab labelled 'lead'). Default off.
"""


class Watcher:
    def __init__(self, session, sock_path, as_json, reap=False):
        self.session = session
        self.sock_path = sock_path
        self.as_json = as_json
        self.reap = reap          # close a worker's tab once output collected
        self.ws = None            # workspace id once resolved
        self.project = None       # workspace cwd (lead/root pane)
        self.last_status = {}     # pane_id -> last agent_status
        self.pane_tab = {}        # pane_id -> tab_id
        self.tab_label = {}       # tab_id -> label
        self.reviews = {}         # label -> {"pane": pane_id, "deadline": monotonic}; in-flight
        self._last_live_check = 0.0  # monotonic ts of the last workspace-liveness check

    # ---- output -----------------------------------------------------------
    def emit(self, event, message, **extra):
        now = datetime.now()
        if self.as_json:
            rec = {"ts": now.isoformat(timespec="seconds"),
                   "session": self.session, "event": event, "message": message}
            rec.update(extra)
            print(json.dumps(rec), flush=True)
        else:
            print("[%s] %s" % (now.strftime("%H:%M:%S"), message), flush=True)

    # ---- herdr plumbing ----------------------------------------------------
    def rpc(self, method, params):
        """One request per connection -- herdr closes the socket after a reply."""
        s = socket.socket(socket.AF_UNIX)
        try:
            s.connect(self.sock_path)
            req = {"id": "ct-watch", "method": method, "params": params}
            s.sendall((json.dumps(req) + "\n").encode())
            buf = b""
            while b"\n" not in buf:
                d = s.recv(65536)
                if not d:
                    break
                buf += d
        finally:
            s.close()
        obj = json.loads(buf.split(b"\n", 1)[0]) if buf.strip() else {}
        if "error" in obj:
            raise RuntimeError(obj["error"].get("message", "rpc error"))
        return obj.get("result", {})

    def refresh(self):
        """Resolve workspace + pane/tab maps; returns the pane list."""
        workspaces = self.rpc("workspace.list", {}).get("workspaces", [])
        ws = next((w["workspace_id"] for w in workspaces
                   if w.get("label") == self.session), None)
        if not ws:
            if self.ws:  # was watching it and it went away
                self.emit("closed", "workspace '%s' closed, exiting" % self.session)
                sys.exit(0)
            raise RuntimeError("no herdr workspace labelled '%s'" % self.session)
        self.ws = ws
        panes = self.rpc("pane.list", {"workspace_id": ws}).get("panes", [])
        tabs = self.rpc("tab.list", {"workspace_id": ws}).get("tabs", [])
        self.pane_tab = {p["pane_id"]: p.get("tab_id") for p in panes}
        self.tab_label = {t["tab_id"]: (t.get("label") or t["tab_id"]) for t in tabs}
        if self.project is None and panes:
            lead = [p for p in panes if self.tab_label.get(p.get("tab_id")) == "lead"]
            self.project = (lead or panes)[0].get("cwd")
        return panes

    def in_ws(self, item_id):  # pane/tab ids are "<ws>:pN" / "<ws>:tN"
        return bool(item_id) and item_id.startswith(self.ws + ":")

    def label_for(self, pane_id):
        if pane_id not in self.pane_tab:
            try:
                self.refresh()
            except (OSError, RuntimeError, json.JSONDecodeError):
                pass
        return self.tab_label.get(self.pane_tab.get(pane_id), pane_id)

    # ---- event actions -----------------------------------------------------
    def notify_blocked(self, label, pane_id):
        title = "%s: %s needs you" % (self.session, label)
        try:
            subprocess.run([HERDR, "notification", "show", title,
                            "--sound", "request"],
                           capture_output=True, timeout=10, check=False)
        except (OSError, subprocess.TimeoutExpired):
            pass
        self.emit("blocked", "%s needs you (blocked)" % label,
                  label=label, pane=pane_id)

    def collect(self, label, pane_id):
        """Save the pane's recent output to results/; True on success."""
        out = ""
        for source in ("recent-unwrapped", "visible"):
            try:
                p = subprocess.run(
                    [HERDR, "pane", "read", pane_id, "--source", source,
                     "--lines", "120"],
                    capture_output=True, text=True, timeout=10, check=False)
                out = p.stdout
            except (OSError, subprocess.TimeoutExpired):
                out = ""
            if out.strip():
                break
        if not self.project:
            self.emit("warn", "%s: no project dir known, output not saved" % label)
            return False
        results = os.path.join(self.project, ".claude-team", "results")
        try:
            os.makedirs(results, exist_ok=True)
            path = os.path.join(results, "%s.md" % label.replace(os.sep, "-"))
            with open(path, "a", encoding="utf-8") as f:
                f.write("\n## %s -- %s / %s\n\n```\n%s\n```\n"
                        % (datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
                           self.session, label, out.rstrip()))
        except OSError as e:
            self.emit("warn", "%s: could not save output (%s)" % (label, e))
            return False
        self.emit("collected", "%s: output -> %s" % (label, path),
                  label=label, pane=pane_id, path=path)
        return True

    def reap_tab(self, label, pane_id):
        """Close a finished worker's tab (--reap). Never the lead tab.
        Returns True when the tab was closed."""
        tab = self.pane_tab.get(pane_id)
        if not tab:
            return False
        if label == "lead" or self.tab_label.get(tab) == "lead":
            return False
        try:
            subprocess.run([HERDR, "tab", "close", tab],
                           capture_output=True, timeout=10, check=False)
        except (OSError, subprocess.TimeoutExpired):
            return False
        self.emit("reaped", "%s: reaped" % label,
                  label=label, pane=pane_id, tab=tab)
        return True

    # ---- completion protocol ------------------------------------------------
    MAX_NUDGES = 2       # end-of-task: fix the deliverable in a couple tries
    PER_TURN_MAX = 8     # per_turn review: continuous feedback needs more cycles
    REVIEW_TIMEOUT = 240 # how long to wait for a reviewer's verdict artifact (s)
    REVIEW_POLL_INTERVAL = 3  # loop-tick cadence (s) for polling in-flight reviews

    def manifest_path(self):
        if not self.project:
            return None
        return os.path.join(self.project, ".claude-team", "manifest",
                            "%s.json" % self.session)

    def manifest(self):
        p = self.manifest_path()
        if not p or not os.path.exists(p):
            return None
        try:
            return json.load(open(p))
        except (OSError, json.JSONDecodeError):
            return None

    def manifest_write(self, doc):
        p = self.manifest_path()
        if not p:
            return
        import tempfile
        fd, tmp = tempfile.mkstemp(dir=os.path.dirname(p))
        with os.fdopen(fd, "w") as f:
            json.dump(doc, f, indent=2)
        os.replace(tmp, p)

    def manifest_mark(self, label, field):
        """Best-effort: set agents[label][field] = True (collected/reaped).
        Skips silently when there is no manifest or no entry for the agent
        (no-deliverable agents may have none); never breaks the event loop."""
        try:
            doc = self.manifest()
            agent = (doc or {}).get("agents", {}).get(label)
            if not isinstance(agent, dict):
                return
            agent[field] = True
            self.manifest_write(doc)
        except (OSError, ValueError, TypeError):
            pass

    def run_verify(self, label):
        """`claude-team verify <session> <label> --json` in the project dir.
        rc==2 means manifest/agent not found (stdout is human text, NOT json)."""
        ct = os.environ.get("CLAUDE_TEAM_BIN", "claude-team")
        try:
            p = subprocess.run([ct, "verify", self.session, label, "--json"],
                               cwd=self.project, capture_output=True, text=True,
                               timeout=180)
        except (OSError, subprocess.TimeoutExpired):
            return None
        if p.returncode == 2:
            return None
        for line in p.stdout.splitlines():
            try:
                obj = json.loads(line)
                if obj.get("agent") == label:
                    return obj
            except json.JSONDecodeError:
                continue
        return None

    # ---- agent-as-verifier (review deliverable) ----------------------------
    def spawn_reviewer(self, label):
        """Launch the reviewer tab for <label> via `claude-team review`. watch is
        herdr-only, so pass --backend explicitly rather than depending on inherited
        env; surface a non-zero exit instead of silently reporting success."""
        ct = os.environ.get("CLAUDE_TEAM_BIN", "claude-team")
        try:
            p = subprocess.run([ct, "review", self.session, label, "--backend", "herdr"],
                               cwd=self.project, capture_output=True, text=True, timeout=90)
        except (OSError, subprocess.TimeoutExpired):
            return False
        if p.returncode != 0:
            self.emit("warn", "%s: reviewer spawn failed (rc=%d): %s"
                      % (label, p.returncode, (p.stderr or p.stdout or "").strip()[:160]),
                      label=label)
            return False
        return True

    def clear_review(self, label, agent):
        """Drop a stale verdict + spawn flag so the next idle re-reviews."""
        agent["review_spawned"] = False
        try:
            os.remove(os.path.join(self.project, ".claude-team", "reviews",
                                   label + ".verdict"))
        except OSError:
            pass

    def verdict_ready(self, label):
        """True once the reviewer has written a valid VERDICT line to its artifact.
        This file — not the reviewer's pane status — is the reliable cross-model
        completion signal (pi/non-Anthropic reviewers don't report working->idle)."""
        vf = os.path.join(self.project, ".claude-team", "reviews", label + ".verdict")
        grades = ("PERFECT", "VERIFIED", "PARTIAL", "FEEDBACK", "FAILED")
        try:
            with open(vf) as fh:
                for ln in fh:
                    s = ln.strip().upper()
                    if s.startswith("VERDICT:") and any(g in s for g in grades):
                        return True
        except OSError:
            pass
        return False

    def pane_for_label(self, label):
        """Resolve a label -> pane_id (refreshes the tab/pane maps first)."""
        try:
            self.refresh()
        except (OSError, RuntimeError, json.JSONDecodeError):
            pass
        tabs = {t for t, l in self.tab_label.items() if l == label}
        for pid, tid in self.pane_tab.items():
            if tid in tabs:
                return pid
        return None

    def register_review(self, label, pane_id):
        """Record a spawned review as in-flight and return immediately — poll_reviews()
        resolves it once the verdict artifact lands or the deadline passes. Non-blocking
        replacement for the old inline await, so concurrent reviews no longer serialize."""
        self.reviews[label] = {"pane": pane_id,
                               "deadline": time.monotonic() + self.REVIEW_TIMEOUT}

    def poll_reviews(self):
        """Resolve every in-flight review whose verdict artifact is ready or whose
        deadline has passed. Called on each loop tick, so reviews complete without
        blocking delivery of other panes' events; multiple reviews resolve
        independently in a single pass."""
        if not self.reviews:
            return
        now = time.monotonic()
        for label in list(self.reviews):
            info = self.reviews[label]
            ready = self.verdict_ready(label)
            if not ready and now < info["deadline"]:
                continue
            del self.reviews[label]               # drop before finishing (no re-entry)
            self.finish_review(label, info["pane"], timed_out=not ready)

    def capture_review_artifact(self, label):
        """Copy the reviewer-authored review file (reviews/<label>.review.md) into
        results/ as the durable audit trail. Returns True when a non-empty review
        was captured; False (caller falls back to the flaky pane scrape) when the
        reviewer wrote nothing. The authored file — not the pane — is the reliable
        record: pi/non-Anthropic reviewers clear their pane, so the scrape is
        usually empty (the gap this closes)."""
        if not self.project:
            return False
        src = os.path.join(self.project, ".claude-team", "reviews", label + ".review.md")
        try:
            with open(src, encoding="utf-8") as fh:
                body = fh.read()
        except OSError:
            return False
        if not body.strip():
            return False
        results = os.path.join(self.project, ".claude-team", "results")
        try:
            os.makedirs(results, exist_ok=True)
            path = os.path.join(results,
                                (label + "-review").replace(os.sep, "-") + ".md")
            with open(path, "a", encoding="utf-8") as fh:
                fh.write("\n## review of %s (authored)\n\n%s\n" % (label, body))
        except OSError:
            return False
        return True

    def finish_review(self, label, pane_id, timed_out=False):
        """Run the parent's completion protocol now that its review is done (verdict
        artifact ready or deadline passed): collect/reap the reviewer tab, run
        protocol_on_finished, then collect/reap the parent and mark the manifest.
        Timed-out reviews still resolve the parent (never stranded). Mirrors the old
        await_and_finish_review tail exactly — only the blocking wait is gone. Relying
        on the verdict artifact (not the reviewer's pane transition) is deliberate: pi
        / non-Anthropic reviewers never emit working->idle."""
        if timed_out:
            self.emit("review", "%s: review timed out (%ds) - resolving parent"
                      % (label, self.REVIEW_TIMEOUT), label=label)
        rpane = self.pane_for_label(label + "-review")   # reviewer's job is done
        # Prefer the reviewer-authored review artifact as the durable audit trail;
        # fall back to scraping the pane only if it didn't write one (pi clears its
        # own pane, so the scrape is frequently empty).
        if not self.capture_review_artifact(label) and rpane:
            self.collect(label + "-review", rpane)
        if rpane and self.reap:
            self.reap_tab(label + "-review", rpane)
        verdict = self.protocol_on_finished(label, pane_id)
        if verdict:
            if self.collect(label, pane_id):
                self.manifest_mark(label, "collected")
            if self.reap and verdict == "met" and self.reap_tab(label, pane_id):
                self.manifest_mark(label, "reaped")

    def maybe_spawn_reviewer(self, label, pane_id, v, agent, doc):
        """Spawn the agent-reviewer and HOLD when its review is pending. In the
        default (end-of-task) mode this waits until the deterministic checks pass;
        in per_turn mode it fires on EVERY worker idle for continuous review.
        Returns True if it took over this idle."""
        if not v:
            return False
        checks = v.get("checks", [])
        review = [c for c in checks if c.get("type") == "review"]
        if not review or agent.get("review_spawned"):
            return False
        pending = any(c.get("review_state") == "pending" for c in review)
        if not pending:
            return False
        per_turn = bool(((agent.get("checks") or {}).get("review") or {}).get("per_turn"))
        nonrev_ok = all(c.get("ok") for c in checks if c.get("type") != "review")
        if not per_turn and not nonrev_ok:
            return False  # end-of-task mode: fix deterministic checks first
        if not self.spawn_reviewer(label):
            self.emit("warn", "%s: could not spawn reviewer" % label, label=label)
            return False
        agent["review_spawned"] = True
        agent["review_pane"] = pane_id
        agent["state"] = "reviewing"
        self.manifest_write(doc)
        self.sidebar(pane_id, "reviewing…")
        self.emit("review", "%s: spawned reviewer (%s), awaiting verdict"
                  % (label, "per-turn" if per_turn else "deterministic checks met"),
                  label=label)
        self.register_review(label, pane_id)   # non-blocking; poll_reviews resolves it
        return True

    def is_our_reviewer(self, reviewer_label):
        """True only if <parent>-review corresponds to a worker WE put under
        review (parent exists in the manifest with review_spawned). Prevents a
        legitimately-named worker like `security-review` being mis-routed."""
        parent = reviewer_label[:-len("-review")]
        agent = (self.manifest() or {}).get("agents", {}).get(parent)
        return bool(agent and agent.get("review_spawned"))

    def on_reviewer_finished(self, reviewer_label, reviewer_pane):
        """A reviewer tab went idle: re-check its parent worker (the verdict
        artifact is now on disk), then clean up the reviewer tab."""
        parent = reviewer_label[:-len("-review")]
        doc = self.manifest()
        agent = (doc or {}).get("agents", {}).get(parent)
        ppane = (agent or {}).get("review_pane")
        # poll_reviews (verdict-artifact-driven) is the primary path; drop any
        # in-flight tracking so it won't ALSO resolve this review. The state guard
        # then prevents a double protocol_on_finished when the poll got here first
        # (it moves state away from "reviewing"). Resolving off manifest state keeps
        # this path working even after a watch restart lost the in-memory registry.
        self.reviews.pop(parent, None)
        if agent and ppane and agent.get("state") == "reviewing":
            self.emit("review", "%s: reviewer finished - re-checking" % parent,
                      label=parent)
            verdict = self.protocol_on_finished(parent, ppane)
            if verdict:
                if self.collect(parent, ppane):
                    self.manifest_mark(parent, "collected")
                if self.reap and verdict == "met" and self.reap_tab(parent, ppane):
                    self.manifest_mark(parent, "reaped")
        # the reviewer itself is transient: collect its notes, reap its tab
        self.collect(reviewer_label, reviewer_pane)
        if self.reap:
            self.reap_tab(reviewer_label, reviewer_pane)

    def sidebar(self, pane_id, text):
        """Best-effort protocol status on the worker's pane (never raises)."""
        try:
            subprocess.run([HERDR, "pane", "report-metadata", pane_id,
                            "--source", "claude-team-watch",
                            "--custom-status", text],
                           capture_output=True, timeout=10, check=False)
        except (OSError, subprocess.TimeoutExpired):
            pass

    def nudge(self, pane_id, text):
        """Guaranteed-submitted instruction to the worker (send-text + enter)."""
        try:
            p1 = subprocess.run([HERDR, "pane", "send-text", pane_id, text],
                                capture_output=True, timeout=10, check=False)
            p2 = subprocess.run([HERDR, "pane", "send-keys", pane_id, "enter"],
                                capture_output=True, timeout=10, check=False)
            return p1.returncode == 0 and p2.returncode == 0
        except (OSError, subprocess.TimeoutExpired):
            return False

    def pane_blocked_sentinel(self, pane_id):
        try:
            p = subprocess.run([HERDR, "pane", "read", pane_id, "--source",
                                "recent-unwrapped", "--lines", "60"],
                               capture_output=True, text=True, timeout=10, check=False)
        except (OSError, subprocess.TimeoutExpired):
            return False
        for line in p.stdout.splitlines():
            s = line.strip()
            # ignore our own instructions echoed in the pane (the only other
            # lines carrying the phrase)
            if "DELIVERABLE UNMET" in s or "escalated to human" in s:
                continue
            # containment, not startswith: real agent output is prefixed
            # (e.g. Claude Code's "⏺ ")
            if "DELIVERABLE BLOCKED:" in s:
                return True
        return False

    def protocol_on_finished(self, label, pane_id):
        """Verify-gated completion. Returns "met", "inert", or False.
        Truthy -> collect may proceed. Only "met" may reap: an uncontracted
        agent going idle is NOT done — reaping it kills a live worker between
        turns (observed live 2026-07-02: --reap culled hand-rolled agents on
        their first idle)."""
        doc = self.manifest()
        agent = (doc or {}).get("agents", {}).get(label)
        checks = (agent or {}).get("checks", {})
        if not agent or not (checks.get("branch_pushed") or checks.get("check")
                             or (checks.get("review") or {})):
            return "inert"  # no deliverable declared -> collect, never reap
        if agent.get("state") in ("blocked", "incomplete"):
            # ABSORBING terminal states: the escalation nudge provokes a worker
            # reply, whose idle would otherwise re-escalate -> infinite loop of
            # toasts/chimes (observed live 2026-07-02). Verify quietly so a met
            # deliverable can still recover to complete; otherwise stay silent.
            v = self.run_verify(label)
            if v and v.get("met"):
                agent["state"] = "complete"
                agent.setdefault("verifications", []).append(
                    {"ts": datetime.now().astimezone().isoformat(timespec="seconds"),
                     "met": True,
                     "detail": "; ".join(c["detail"] for c in v.get("checks", []))})
                self.manifest_write(doc)
                self.sidebar(pane_id, "✓ complete")
                self.emit("verified", "%s: deliverable met (recovered after "
                          "escalation)" % label, label=label)
                return "met"
            self.emit("absorbed", "%s: still %s - staying quiet (escalated "
                      "already)" % (label, agent["state"]), label=label)
            return False
        self.sidebar(pane_id, "verifying…")
        v = self.run_verify(label)
        met = bool(v and v.get("met"))
        detail = ("verify failed to run (infra/timeout) - not the worker's fault"
                  if v is None else
                  "; ".join(c["detail"] for c in v.get("checks", [])))
        agent.setdefault("verifications", []).append(
            {"ts": datetime.now().astimezone().isoformat(timespec="seconds"),
             "met": met, "detail": detail})
        if met:
            agent["state"] = "complete"
            self.manifest_write(doc)
            self.sidebar(pane_id, "✓ complete")
            self.emit("verified", "%s: deliverable met" % label, label=label)
            return "met"
        # unmet only because an agent-review is still pending -> spawn the
        # reviewer and hold, rather than nudging the worker for its absence.
        if self.maybe_spawn_reviewer(label, pane_id, v, agent, doc):
            return False
        # a reviewer that finished without a valid verdict is the reviewer's
        # problem, not the worker's -> escalate to human, don't nudge the worker.
        if v and any(c.get("review_state") == "malformed" for c in v.get("checks", [])):
            agent["state"] = "incomplete"
            self.manifest_write(doc)
            self.sidebar(pane_id, "✗ reviewer needs you")
            self.notify_blocked(label, pane_id)
            self.emit("escalated", "%s: reviewer wrote no valid verdict - "
                      "escalated to human" % label, label=label, state="incomplete")
            return False
        per_turn = bool(((agent.get("checks") or {}).get("review") or {}).get("per_turn"))
        cap = self.PER_TURN_MAX if per_turn else self.MAX_NUDGES
        blocked = self.pane_blocked_sentinel(pane_id)
        if blocked or agent.get("nudges", 0) >= cap:
            agent["state"] = "blocked" if blocked else "incomplete"
            self.manifest_write(doc)
            self.sidebar(pane_id, "✗ %s — needs you" % agent["state"])
            self.notify_blocked(label, pane_id)
            if not self.nudge(pane_id, "deliverable unmet after %d nudge(s) - "
                              "escalated to human; stand by"
                              % agent.get("nudges", 0)):
                self.emit("warn", "%s: nudge delivery failed - check the pane"
                          % label, label=label)
            self.emit("escalated",
                      "%s: %s - escalated to human" % (label, agent["state"]),
                      label=label, state=agent["state"])
            return False  # never reap
        agent["nudges"] = agent.get("nudges", 0) + 1
        agent["state"] = "working"
        if v and any(c.get("type") == "review" and not c.get("ok")
                     for c in v.get("checks", [])):
            self.clear_review(label, agent)  # stale/failed verdict -> fresh re-review
        self.manifest_write(doc)
        if v is None:
            failing = "deliverable verification could not run - retrying next idle"
            nudge_text = failing
        else:
            failing = "; ".join(c["detail"] for c in v.get("checks", [])
                                if not c.get("ok")) or "deliverable checks failed"
            if per_turn:
                nudge_text = ("REVIEW (turn %d): %s - incorporate this and continue; "
                              "state DELIVERABLE BLOCKED: <reason> only if truly stuck"
                              % (agent["nudges"], failing))
            else:
                nudge_text = ("DELIVERABLE UNMET: %s - finish the deliverable or "
                              "state DELIVERABLE BLOCKED: <reason>" % failing)
        if not self.nudge(pane_id, nudge_text):
            self.emit("warn", "%s: nudge delivery failed - check the pane"
                      % label, label=label)
        self.sidebar(pane_id, "nudged ×%d" % agent["nudges"])
        self.emit("nudged", "%s: nudged (%d/%d): %s"
                  % (label, agent["nudges"], cap, failing),
                  label=label, nudges=agent["nudges"])
        return False  # not complete yet; await next idle

    # ---- event dispatch ----------------------------------------------------
    def handle(self, obj, subscribed_panes, known_tabs):
        """Returns True when a re-subscribe (fresh connection) is needed."""
        data = obj.get("data") or {}
        ev = (obj.get("event") or data.get("type") or "").replace(".", "_")

        # agent status change (agent panes only: events carrying agent/status)
        if data.get("agent_status") and data.get("pane_id"):
            pane, status = data["pane_id"], data["agent_status"]
            if not self.in_ws(pane):
                return False
            prev = self.last_status.get(pane)
            if status == prev:
                return False
            self.last_status[pane] = status
            label = self.label_for(pane)
            self.emit("status", "%s: %s -> %s" % (label, prev or "unknown", status),
                      label=label, pane=pane, status=status, prev=prev)
            if status == "blocked":
                self.notify_blocked(label, pane)
            elif status in ("idle", "done") and prev == "working":
                self.emit("finished", "%s: finished" % label, label=label, pane=pane)
                if label.endswith("-review") and self.is_our_reviewer(label):
                    self.on_reviewer_finished(label, pane)
                    return False
                verdict = self.protocol_on_finished(label, pane)
                if verdict:
                    collected = self.collect(label, pane)
                    if collected:
                        self.manifest_mark(label, "collected")
                    # reap ONLY on a verified deliverable — an idle uncontracted
                    # agent is between turns, not done
                    if self.reap and collected and verdict == "met":
                        if self.reap_tab(label, pane):
                            self.manifest_mark(label, "reaped")
            return False

        pane = data.get("pane_id") or (data.get("pane") or {}).get("pane_id")
        tab = data.get("tab_id") or (data.get("tab") or {}).get("tab_id")
        if ev in ("pane_exited", "pane_closed") and self.in_ws(pane):
            label = self.label_for(pane)
            what = "pane exited" if ev == "pane_exited" else "pane closed"
            self.emit(ev, "%s: %s" % (label, what), label=label, pane=pane)
            return False
        # new pane/tab in our workspace -> re-subscribe so it gets status events
        # (guarded: subscribing replays historical created events)
        if ev == "pane_created" and self.in_ws(pane) and pane not in subscribed_panes:
            self.emit("resubscribe", "new pane %s, re-subscribing" % pane, pane=pane)
            return True
        if ev == "tab_created" and self.in_ws(tab) and tab not in known_tabs:
            self.emit("resubscribe", "new tab %s, re-subscribing" % tab, tab=tab)
            return True
        if ev == "tab_closed" and self.in_ws(tab):
            self.emit(ev, "%s: tab closed" % self.tab_label.get(tab, tab), tab=tab)
        return False

    # ---- main loops ----------------------------------------------------------
    LIVENESS_INTERVAL = 30.0  # re-check the workspace still exists every N seconds

    def _maybe_check_alive(self):
        """Periodically confirm our workspace still exists; exit cleanly if it was
        closed (via `claude-team --stop`, a crash, or a manual close). Closing a
        workspace does NOT close the watcher's global event socket, so without this
        the tick loop would select on a silent socket forever — a leaked process
        (the exact symptom we saw). Cheap: at most one workspace.list RPC every
        LIVENESS_INTERVAL seconds. Reuses refresh()'s exit convention (sys.exit 0)."""
        now = time.monotonic()
        if now - self._last_live_check < self.LIVENESS_INTERVAL:
            return
        self._last_live_check = now
        try:
            wss = self.rpc("workspace.list", {}).get("workspaces", [])
        except (OSError, RuntimeError, json.JSONDecodeError):
            return  # transient RPC failure — retry next interval, never exit on error
        if self.ws and not any(w.get("label") == self.session for w in wss):
            self.emit("closed", "workspace '%s' closed, exiting" % self.session)
            sys.exit(0)

    def _tick(self, s, timeout):
        """Block up to `timeout`s for event-socket data, then ALWAYS poll in-flight
        reviews (and periodically check the workspace is still alive) before
        returning. Returns the bytes read, or b'' when the tick only polled (select
        timed out). Raises ConnectionError if the socket closed. This is the seam
        that lets the loop reach poll_reviews() on an idle system — a verdict lands
        asynchronously, so a purely event-driven loop would never see it."""
        ready, _, _ = select.select([s], [], [], timeout)
        self.poll_reviews()
        self._maybe_check_alive()
        if not ready:
            return b""
        d = s.recv(65536)
        if not d:
            raise ConnectionError("event socket closed")
        return d

    def watch_once(self):
        """One subscribe connection; returns when a re-subscribe is needed."""
        panes = self.refresh()
        subscribed = set(self.pane_tab)
        known_tabs = set(self.tab_label)
        subs = [{"type": "pane.agent_status_changed", "pane_id": p["pane_id"]}
                for p in panes]
        subs += [{"type": t} for t in ("pane.created", "pane.closed", "pane.exited",
                                       "tab.created", "tab.closed")]
        s = socket.socket(socket.AF_UNIX)
        try:
            s.connect(self.sock_path)
            s.sendall((json.dumps({"id": "watch", "method": "events.subscribe",
                                   "params": {"subscriptions": subs}}) + "\n").encode())
            self.emit("watching", "watching %s (%s): %d pane(s)"
                      % (self.session, self.ws, len(panes)),
                      workspace=self.ws, panes=sorted(subscribed))
            buf = b""
            while True:  # tick loop: block <=interval for data, then poll reviews
                # raw recv (makefile buffering drops events); _tick also polls
                # in-flight reviews every tick, incl. idle ticks with no data
                d = self._tick(s, self.REVIEW_POLL_INTERVAL)
                if not d:
                    continue          # idle tick: only polled in-flight reviews
                buf += d
                while b"\n" in buf:
                    line, buf = buf.split(b"\n", 1)
                    if not line.strip():
                        continue
                    obj = json.loads(line)
                    if "result" in obj:  # subscription_started ack
                        continue
                    if self.handle(obj, subscribed, known_tabs):
                        return
        finally:
            s.close()

    def run(self):
        first = True
        while True:
            try:
                # watch_once refreshes state itself; it exits 0 if the
                # workspace disappears after we started watching it.
                self.watch_once()   # returned -> re-subscribe immediately
            except (OSError, ConnectionError, RuntimeError,
                    json.JSONDecodeError) as e:
                if first:
                    print("claude-team-watch: %s" % e, file=sys.stderr)
                    sys.exit(1)
                self.emit("reconnect", "connection lost (%s); retrying in 2s" % e)
                time.sleep(2)
            first = False


def main(argv):
    session, as_json, reap = None, False, False
    sock = os.environ.get("HERDR_SOCKET_PATH", DEFAULT_SOCKET)
    args = iter(argv)
    for a in args:
        if a in ("-h", "--help"):
            sys.stderr.write(USAGE)
            return 2
        if a == "--socket":
            sock = next(args, "") or sock
        elif a == "--json":
            as_json = True
        elif a == "--reap":
            reap = True
        elif a.startswith("-"):
            sys.stderr.write("unknown option: %s\n%s" % (a, USAGE))
            return 2
        elif session is None:
            session = a
    if not session:
        sys.stderr.write(USAGE)
        return 2
    signal.signal(signal.SIGTERM, lambda *_: sys.exit(0))
    try:
        Watcher(session, sock, as_json, reap).run()
    except KeyboardInterrupt:
        return 0
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
