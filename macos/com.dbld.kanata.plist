<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.dbld.kanata</string>

  <!-- kanata as the keyboard remapper (caps tap=Esc/hold=Option, home-row Ctrl on d/k).
       Needs root for the Karabiner VirtualHIDDevice driver; Input Monitoring must be granted
       to /opt/homebrew/bin/kanata. Mirrors the frame's services.kanata. -->
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/kanata</string>
    <string>--cfg</string>
    <string>/Users/dbld/.code/dotfiles/kanata/base.kbd</string>
  </array>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/kanata.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/kanata.err.log</string>
</dict>
</plist>
